SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

IG_APP_ID=your-meta-app-id
IG_APP_SECRET=your-meta-app-secret
IG_REDIRECT_URI=https://your-api.railway.app/auth/instagram/callback

SC_CLIENT_ID=your-soundcloud-client-id
SC_CLIENT_SECRET=your-soundcloud-client-secret

TOKEN_ENCRYPTION_KEY=your-fernet-key-here

FRONTEND_URL=http://localhost:5173

# Beatport — uses your personal Beatport account to authenticate
# The OAuth client_id is scraped automatically from the Beatport docs page (no developer registration needed)
# Store your Beatport account credentials here — never commit these values
BEATPORT_USERNAME=your-beatport-username
BEATPORT_PASSWORD=your-beatport-password

# Twitch — get credentials at https://dev.twitch.tv/console/apps
# Create an app → choose "Confidential" type → copy Client ID and Client Secret
# No user OAuth needed — the app access token (client credentials) covers public stream data
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
